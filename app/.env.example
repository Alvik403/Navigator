KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_URL=http://localhost:8080
WEB_URL=http://localhost:5173
MAX_BOT_BASE_URL=https://max.ru/id482403059838_2_bot
WEB_RETURN_URL=http://localhost:5173/max
MAX_BOT_TOKEN=
# Локальная БД приложения поднимается отдельным контейнером app-postgres.
DATABASE_URL=postgresql://max_rass:max_rass@app-postgres:5432/max_rass
# Пример: {"467705969":{"username":"hr.manager","password":"hr123456","label":"HR","role":"hr_manager"}}
MAX_USER_MAP_JSON=
# Контакт HR для новых пользователей в боте (текст + кнопки-ссылки)
# HR_CONTACT_NAME=Отдел кадров
# HR_MAX_PROFILE_URL=https://max.ru/...
# HR_CONTACT_URL=https://forms.gle/xxxxxxxx
# HR_PORTAL_URL=http://localhost:5173
# Ссылка на localhost допустима в тексте, но не в кнопках MAX — для кнопок нужен публичный https-URL.
# Напоминания о занятиях (worker в max-auth)
APP_TIMEZONE=Europe/Moscow
LESSON_REMINDER_POLL_SEC=60
LESSON_REMINDER_WINDOW_MIN=2
LESSON_REMINDER_ENABLED=true
